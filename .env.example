# ============================================================
# MCP Server API Keys - Copy this file to .env and fill in
# your actual values. Never commit .env to version control.
# ============================================================

# Context7 - Up-to-date library documentation
# Get your key at: https://context7.com
CONTEXT7_API_KEY=your_context7_api_key_here

# GitHub - Repository, issues, PRs, and workflow management
# Create a PAT at: https://github.com/settings/tokens
# Recommended scopes: repo, read:org, notifications
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_pat_here

# Google OAuth Credentials (shared by Gmail and Google Calendar)
# Steps:
#   1. Go to https://console.cloud.google.com
#   2. Create a project and enable Gmail API + Google Calendar API
#   3. Create OAuth 2.0 credentials (Desktop app type)
#   4. Download the JSON file and set the path below
GOOGLE_OAUTH_CREDENTIALS=/path/to/your/gcp-oauth.keys.json

# Google Search
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=